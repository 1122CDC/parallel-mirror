PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
DATABASE_URL=file:./dev.db
UPLOAD_DIR=./uploads
# 生产环境可以改成真正的外部数据库连接串，例如：
# DATABASE_URL=postgresql://user:password@host:5432/whm?schema=public
# 如果使用 Render 这类平台，建议把上传目录放到持久磁盘里，例如：
# UPLOAD_DIR=/var/data/uploads
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_TEXT_MODEL=deepseek-chat
AI_PROXY_BASE_URL=https://128api.cn/v1
AI_PROXY_API_KEY=your_ai_image_proxy_api_key
AI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
AI_REQUEST_TIMEOUT_MS=60000
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=后台管理员
ADMIN_PASSWORD=admin123456
ADMIN_TOKEN_SECRET=change_me_in_production
ADMIN_TOKEN_TTL_MS=86400000
